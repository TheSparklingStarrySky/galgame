{
  "version": 7,
  "status": "p0_pixabay_and_p1_original_finale_integrated",
  "format": {
    "master": "wav, 48kHz, 24-bit",
    "bgm": "runtime MP3 or AAC/M4A, stereo",
    "sfx": "runtime MP3 or AAC/M4A, mono or stereo",
    "voice": "ogg, mono, 48kHz, -18 LUFS target",
    "downloaded": "mp3, original Pixabay sample rate and mix"
  },
  "mix": {
    "bgmTargetLufs": -21,
    "ambienceTargetLufs": -27,
    "sfxPeakDb": -3,
    "voiceTargetLufs": -18,
    "voiceDuckingDb": -7,
    "bgmCrossfadeMs": 860
  },
  "sourceProcessing": {
    "readyForAudition": true,
    "runtimeIntegrated": true,
    "runtimeFormat": "mp3 + aac/m4a",
    "longOneShotsUsePlaybackCaps": true,
    "requiresTrimLoopAndLoudnessPass": false,
    "records": "assets/audio/pixabay_sources.json + assets/audio/original_sources.json",
    "cueResolver": "lib/audio/audio_cues.dart",
    "playbackController": "lib/audio/game_audio_controller.dart"
  },
  "sourcePolicy": {
    "allowed": [
      "pixabay_content_license",
      "paid_ai_commercial_license",
      "commissioned_original"
    ],
    "requiredRecords": [
      "source_url",
      "creator_or_model",
      "download_or_generation_date",
      "license_snapshot",
      "original_filename",
      "edit_log"
    ],
    "reject": [
      "standalone_redistribution_only",
      "unclear_commercial_rights",
      "artist_or_existing_song_imitation",
      "unresolved_content_id_risk"
    ]
  },
